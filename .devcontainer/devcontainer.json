{
  "name": "Power Platform PCF - Extension Managed (pnpm)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  
  // Forward port for the local PCF test harness (pnpm start)
  "forwardPorts": [8181],
  
  "customizations": {
    "vscode": {
      "extensions": [
        "microsoft-IsvExpTools.powerplatform-vscode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-dotnettools.csdevkit"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Automatically restore your node_modules using pnpm on startup
  "postCreateCommand": "pnpm install",

  "remoteUser": "node"
}
