{
  "name": "pcf-project",
  "version": "1.0.0",
  "description": "Project containing your PowerApps Component Framework (PCF) control.",
  "scripts": {
    "copy-tinymce-skins": "xcopy node_modules\\tinymce\\skins OFRTinyMCEEditor\\assets\\skins /E /I /Y",
    "build": "npm run copy-tinymce-skins && pcf-scripts build",
    "clean": "pcf-scripts clean",
    "lint": "pcf-scripts lint",
    "lint:fix": "pcf-scripts lint fix",
    "rebuild": "pcf-scripts rebuild",
    "start": "npm run copy-tinymce-skins && pcf-scripts start",
    "start:watch": "npm run copy-tinymce-skins && pcf-scripts start watch",
    "refreshTypes": "pcf-scripts refreshTypes"

  },
  "dependencies": {
    "@fluentui/react-components": "9.68.0",
    "@tinymce/tinymce-react": "^6.3.0",
    "react": "16.14.0",
    "react-dom": "16.14.0",
    "tinymce": "^8.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@microsoft/eslint-plugin-power-apps": "^0.2.51",
    "@types/powerapps-component-framework": "^1.3.16",
    "@types/react": "^16.14.60",
    "@types/react-dom": "^16.9.24",
    "css-loader": "^7.1.2",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-react": "^7.37.2",
    "globals": "^15.15.0",
    "pcf-scripts": "^1",
    "pcf-start": "^1",
    "react": "^16.14.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "8.44.0"
  }
}
